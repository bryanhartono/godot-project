[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/lobby.gd" id="1"]
[ext_resource type="Font" path="res://assets/Fonts/Kenney Future.ttf" id="2"]

[node name="Lobby" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.08, 0.16, 1)

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -300.0
offset_right = 300.0
offset_bottom = 300.0
theme_override_constants/separation = 14

[node name="RoomCodeLabel" type="Label" parent="VBox"]
text = "GRID RUN"
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.0, 0.95, 1.0, 1)
theme_override_font_sizes/font_size = 42
theme_override_fonts/font = ExtResource("2")

[node name="CharacterRow" type="HBoxContainer" parent="VBox"]
theme_override_constants/separation = 10

[node name="HostButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(0.0, 56.0)
text = "Host Game"
theme_override_font_sizes/font_size = 28

[node name="CodeInput" type="LineEdit" parent="VBox"]
custom_minimum_size = Vector2(0.0, 52.0)
placeholder_text = "Enter host IP address"
theme_override_font_sizes/font_size = 26

[node name="JoinButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(0.0, 56.0)
text = "Join Game"
theme_override_font_sizes/font_size = 28

[node name="SoloButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(0.0, 56.0)
text = "Play Solo"
theme_override_font_sizes/font_size = 28

[node name="StartButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(0.0, 56.0)
text = "Start Run"
theme_override_font_sizes/font_size = 28
visible = false

[node name="PlayerList" type="VBoxContainer" parent="VBox"]
theme_override_constants/separation = 6

[node name="StatusLabel" type="Label" parent="VBox"]
text = ""
horizontal_alignment = 1
theme_override_font_sizes/font_size = 26

[connection signal="pressed" from="VBox/HostButton" to="." method="_on_host_pressed"]
[connection signal="pressed" from="VBox/JoinButton" to="." method="_on_join_pressed"]
[connection signal="pressed" from="VBox/SoloButton" to="." method="_on_solo_pressed"]
[connection signal="pressed" from="VBox/StartButton" to="." method="_on_start_pressed"]
